{
    "manifest_version": 3,
    "name": "YouTube Music Discord Rich Presence",
    "version": "1.0",
    "description": "Shows your YouTube Music playback in Discord via Rich Presence",
    "permissions": ["activeTab", "tabs"],
    "host_permissions": ["https://music.youtube.com/*"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["https://music.youtube.com/*"],
        "js": ["content.js"]
      }
    ],
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }